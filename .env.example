# Database
DATABASE_URL="postgresql://user:password@localhost:5432/probook_web?schema=public"   # Pooled (pgBouncer) URL used by the app
DIRECT_URL="postgresql://user:password@localhost:5432/probook_web?schema=public"     # Direct (non-pooled) URL — required for prisma migrate (DDL fails through pgBouncer)

# Auth
JWT_SECRET="generate-a-random-64-char-string-here"
TOTP_ENCRYPTION_KEY="generate-a-separate-random-64-char-string"  # Encrypts stored TOTP secrets. Set BEFORE rotating JWT_SECRET or 2FA secrets become undecryptable.
INVOICE_INTEGRITY_SECRET=    # Optional: HMAC key for invoice integrity hashes (falls back to JWT_SECRET)

# Supabase (Storage + Database)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Resend)
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="Probook <noreply@yourdomain.com>"

# App
NEXT_PUBLIC_APP_NAME="Probook"
NEXT_PUBLIC_SITE_URL="https://probookapp.net"   # Used for SEO, sitemap, OG image URLs
NEXT_PUBLIC_APP_URL="https://probookapp.net"    # Used in email links (verification, password reset)
NEXT_PUBLIC_API_URL=                             # Optional: API base URL override (defaults to same origin)

# Rate limiting (Upstash Redis — required in production for effective limits;
# falls back to per-instance in-memory when unset, e.g. local dev/tests)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Scheduled jobs (Vercel Cron sends this as a Bearer token to /api/cron/*)
CRON_SECRET=

# Admin Seed
PLATFORM_ADMIN_PASSWORD=     # Password for the initial platform admin account

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=      # Get from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_AUTH_TOKEN=           # Optional: for source map uploads (Settings → Auth Tokens)
SENTRY_ORG=                  # Optional: your Sentry org slug
SENTRY_PROJECT=              # Optional: your Sentry project slug
